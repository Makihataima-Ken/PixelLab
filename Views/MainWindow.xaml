<Window x:Class="PixelLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PixelLab"
        mc:Ignorable="d"
        Title="PixelLab" Height="700" Width="1200"
        AllowDrop="True" Drop="Window_Drop">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <TabControl Background="#1E1E1E">
        <TabItem Header="Image Lab" Foreground="Black">
            <Grid Background="#1E1E1E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- TOP TOOLBAR -->
                <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Background="#2D2D30" Margin="10">
                    <TextBlock Text="PixelLab" FontSize="20" Foreground="White" Margin="0 0 20 0" VerticalAlignment="Center"/>
                    <Button Content="Load Image" Width="100" Margin="0 0 10 0" Command="{Binding LoadImageCommand}"/>
                    <Button Content="Save Image" Width="100" Margin="0 0 10 0" Command="{Binding SaveImageCommand}"/>
                    <Button Content="Reset" Width="100" Margin="0 0 10 0" Command="{Binding ResetImageCommand}"/>
                    
                    <TextBlock Text="Color System:" Foreground="White" Margin="20 0 10 0" VerticalAlignment="Center"/>
                    <ComboBox Width="120" VerticalAlignment="Center"
                              ItemsSource="{Binding AvailableSystems}"
                              SelectedItem="{Binding Settings.CurrentSystem}"/>
                </StackPanel>

                <!-- LEFT PANEL -->
                <StackPanel Grid.Row="1" Grid.Column="0" Background="#252526" Margin="10" DataContext="{Binding Settings}">

                    <TextBlock Text="Channels" FontSize="18" Foreground="White" Margin="0 0 0 20"/>

                    <!-- Channel 1 -->
                    <StackPanel Margin="0 0 0 15">
                        <CheckBox Content="{Binding Channel1Name}" IsChecked="{Binding Channel1Enabled}" Foreground="White" Margin="0 0 0 5"/>
                        <Slider Minimum="{Binding Channel1Min}" Maximum="{Binding Channel1Max}" Value="{Binding Channel1Value}" IsEnabled="{Binding Channel1Enabled}"/>
                    </StackPanel>

                    <!-- Channel 2 -->
                    <StackPanel Margin="0 0 0 15">
                        <CheckBox Content="{Binding Channel2Name}" IsChecked="{Binding Channel2Enabled}" Foreground="White" Margin="0 0 0 5"/>
                        <Slider Minimum="{Binding Channel2Min}" Maximum="{Binding Channel2Max}" Value="{Binding Channel2Value}" IsEnabled="{Binding Channel2Enabled}"/>
                    </StackPanel>

                    <!-- Channel 3 -->
                    <StackPanel Margin="0 0 0 15">
                        <CheckBox Content="{Binding Channel3Name}" IsChecked="{Binding Channel3Enabled}" Foreground="White" Margin="0 0 0 5"/>
                        <Slider Minimum="{Binding Channel3Min}" Maximum="{Binding Channel3Max}" Value="{Binding Channel3Value}" IsEnabled="{Binding Channel3Enabled}"/>
                    </StackPanel>

                    <!-- Channel 4 -->
                    <StackPanel Margin="0 0 0 15" Visibility="{Binding IsChannel4Visible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <CheckBox Content="{Binding Channel4Name}" IsChecked="{Binding Channel4Enabled}" Foreground="White" Margin="0 0 0 5"/>
                        <Slider Minimum="{Binding Channel4Min}" Maximum="{Binding Channel4Max}" Value="{Binding Channel4Value}" IsEnabled="{Binding Channel4Enabled}"/>
                    </StackPanel>

                </StackPanel>

                <!-- CENTER IMAGE -->
                <Border Grid.Row="1" Grid.Column="1" Margin="10" Background="#333">
                    <Image Source="{Binding DisplayedImage}" Stretch="Uniform"/>
                </Border>

                <!-- RIGHT PANEL -->
                <StackPanel Grid.Row="1" Grid.Column="2" Background="#252526" Margin="10">
                    
                    <TextBlock Text="Color Quantization" FontSize="24" Foreground="White" Margin="0 0 0 10"/>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                        <TextBlock Text="Palette:" Foreground="White" VerticalAlignment="Center" Margin="0 0 10 0"/>
                        <ComboBox Width="120"
                                  ItemsSource="{Binding QuantizationOptions}"
                                  DisplayMemberPath="Label"
                                  SelectedItem="{Binding SelectedQuantizationOption}"/>
                    </StackPanel>

                    <TextBlock Text="Image Info" FontSize="24" Foreground="White" Margin="0 0 0 20"/>

                    <Grid DataContext="{Binding ImageInfoData}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name: " Foreground="LightGray" Margin="0,5"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FileName}" Foreground="White" Margin="5,5" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Format: " Foreground="LightGray" Margin="0,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Format}" Foreground="White" Margin="5,5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Width: " Foreground="LightGray" Margin="0,5"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Width}" Foreground="White" Margin="5,5"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Height: " Foreground="LightGray" Margin="0,5"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Height}" Foreground="White" Margin="5,5"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Size: " Foreground="LightGray" Margin="0,5"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding FormattedStorageSize}" Foreground="White" Margin="5,5"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Total Pixels: " Foreground="LightGray" Margin="0,5"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding TotalPixels}" Foreground="White" Margin="5,5"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </TabItem>

        <TabItem Header="Color Plane" Foreground="Black">
            <Grid Background="#1E1E1E">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Background="#252526" Margin="10 10 10 0">
                    <TextBlock Text="2D Color Plane" FontSize="18" Foreground="White" Margin="0 0 0 4"/>
                    <TextBlock x:Name="ColorSpace2DDescription" Foreground="LightGray" TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Row="1" Grid.Column="0" Margin="10" Background="#222" ClipToBounds="True">
                    <Grid>
                        <Image x:Name="ColorSpace2DImage"
                               Stretch="Fill"
                               MouseMove="ColorSpace2DImage_MouseMove"
                               MouseLeave="ColorSpace2DImage_MouseLeave"/>
                        <Canvas IsHitTestVisible="False">
                            <Ellipse x:Name="ColorHoverMarker"
                                     Width="14"
                                     Height="14"
                                     Stroke="White"
                                     StrokeThickness="2"
                                     Fill="#66000000"
                                     Visibility="Collapsed"/>
                        </Canvas>
                    </Grid>
                </Border>

                <StackPanel Grid.RowSpan="2" Grid.Column="1" Background="#252526" Margin="10">
                    <TextBlock Text="Plane Model" FontSize="20" Foreground="White" Margin="0 0 0 10"/>
                    <ComboBox x:Name="ColorSystemComboBox" Margin="0 0 0 20"
                              ItemsSource="{Binding AvailableSystems}"
                              SelectedItem="{Binding Settings.CurrentSystem, Mode=TwoWay}"
                              SelectionChanged="ColorSystemComboBox_SelectionChanged"/>

                    <TextBlock Text="Hover Preview" FontSize="20" Foreground="White" Margin="0 0 0 10"/>
                    <Border x:Name="HoveredColorSwatch"
                            Width="64"
                            Height="64"
                            HorizontalAlignment="Left"
                            Background="Black"
                            BorderBrush="White"
                            BorderThickness="1"
                            Margin="0 0 0 20"/>

                    <TextBlock Text="Selected Color Info" FontSize="20" Foreground="White" Margin="0 0 0 20"/>
                    <TextBlock Text="Hover over a point on the 2D plane to inspect that pixel color across all supported color systems."
                               Foreground="LightGray" TextWrapping="Wrap" Margin="0 0 0 20"/>
                    <TextBlock Text="{Binding SelectedColorValues}" Foreground="White" TextWrapping="Wrap" FontFamily="Consolas"/>
                </StackPanel>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
