<Window x:Class="PixelLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PixelLab"
        mc:Ignorable="d"
        Title="PIxelLab" Height="700" Width="1200">
    <Grid Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <StackPanel Grid.Column="0"
                    Background="#252526"
                    >

            <TextBlock Text="PixelLab"
                       FontSize="28"
                       Foreground="White"
                       Margin="0 0 0 20"/>

            <Button Content="Load Image"
                    Height="40"
                    Margin="0 0 0 10"
                    Command="{Binding LoadImageCommand}"/>

            <Button Content="Reset Image"
                    Height="40"
                    Command="{Binding ResetImageCommand}"/>
                    
            <TextBlock Text="Red"
                    Foreground="White"
                    Margin="0 20 0 5"/>

            <Slider Minimum="0"
                    Maximum="2"
                    Value="{Binding RedMultiplier}"
                    TickFrequency="0.1"/>

            <TextBlock Text="Green"
                    Foreground="White"
                    Margin="0 20 0 5"/>

            <Slider Minimum="0"
                    Maximum="2"
                    Value="{Binding GreenMultiplier}"
                    TickFrequency="0.1"/>

            <TextBlock Text="Blue"
                    Foreground="White"
                    Margin="0 20 0 5"/>

            <Slider Minimum="0"
                    Maximum="2"
                    Value="{Binding BlueMultiplier}"
                    TickFrequency="0.1"/>

        </StackPanel>

        <!-- CENTER IMAGE -->
        <Border Grid.Column="1"
                Margin="10"
                Background="#333">

            <Image Source="{Binding DisplayedImage}"
                   Stretch="Uniform"/>
        </Border>

        <!-- RIGHT PANEL -->
        <StackPanel Grid.Column="2"
                    Background="#252526"
                    >

            <TextBlock Text="Image Info"
                       FontSize="24"
                       Foreground="White"/>

        </StackPanel>

    </Grid>
</Window>
